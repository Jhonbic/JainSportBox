# Base URL del backend. Si se omite, usa http://127.0.0.1:8000 (dev local).
#
# Build en la nube (Vercel/Netlify): define VITE_API_URL con el dominio del API.
#   Se puede setear en el dashboard del host (recomendado) o en .env.production.
# Estación de huella local (recepción): crea .env.local con el MISMO valor cloud,
#   porque la estación también consume el backend en la nube por HTTPS.
#
# VITE_API_URL=https://api.tudominio.com
