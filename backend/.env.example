# Conexion a la base de datos.
# Local (por defecto si se omite): SQLite -> sqlite:///crossfit.db
# Produccion: URL de PostgreSQL. Acepta el formato "postgres://" que entrega
# Railway/Render; database.py lo normaliza a "postgresql+psycopg://".
# DATABASE_URL=postgresql+psycopg://usuario:password@host:5432/jainsportbox

# Clave secreta para firmar tokens JWT — cambia esto en produccion
SECRET_KEY=XK9#mP2$vL7qRnT4wYjB8cAeZsUdHfGi

# Credenciales del usuario administrador por defecto
ADMIN_NOMBRE=Jain Admin
ADMIN_EMAIL=admin@jainsportbox.com
ADMIN_PASSWORD=JainAdmin2024#
ADMIN_TELEFONO=+57 300 123 4567
ADMIN_DOCUMENTO=1020456789

# Clave secreta usada por el bridge .NET para autenticarse sin JWT
BRIDGE_SECRET=jain_bridge_secret_2024

# Orígenes CORS permitidos (coma-separado). Local usa los puertos de Vite por
# defecto si se omite. En producción: dominios del frontend.
# CORS_ORIGINS=https://app.tudominio.com,http://localhost:4173

# Almacenamiento de fotos en object storage S3-compatible (Cloudflare R2 / S3).
# Si S3_BUCKET se define, las fotos van al bucket; si no, al filesystem local.
# Necesario en la nube (Railway/Render tienen filesystem efímero).
# S3_BUCKET=jainsportbox-uploads
# S3_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev
# S3_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=auto